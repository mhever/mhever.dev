# Anthropic API key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Path to your system prompt file (local development)
SYSTEM_PROMPT_PATH=../system-prompt/system-prompt.md

# Admin panel password
ADMIN_PASSWORD=changeme

# Rate limits (optional, defaults shown)
RATE_LIMIT_PER_IP=10
RATE_LIMIT_GLOBAL=100

# CORS origin (optional, defaults to * in dev)
# CORS_ORIGIN=https://martonhever.dev

